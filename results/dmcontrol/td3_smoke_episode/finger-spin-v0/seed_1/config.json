{
  "algo": "td3_smoke_episode",
  "backend": "dmcontrol",
  "batch_size": 16,
  "buffer_size": 1000000,
  "cuda": true,
  "debug": false,
  "device": "cpu",
  "env_name": "finger-spin-v0",
  "eval_copies_obs_norm_stats": true,
  "eval_episodes": 1,
  "eval_interval": 1000,
  "eval_uses_reward_scaling": false,
  "exploration_noise": 0.1,
